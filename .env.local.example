DATABASE_URL=
RESEND_API_KEY=
NOTIFICATION_EMAIL=
CRON_SECRET=
NEXT_PUBLIC_APP_URL=
GEMINI_API_KEY=
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_REDIRECT_URI=
APP_PASSWORD=
AUTH_SECRET=
# MoneyForwardトークンをDB保存する際の暗号化鍵（32バイト）。生成: openssl rand -base64 32
# 未設定だとMF連携は保存できず未連携扱いになる。設定/変更後は一度MF再連携が必要。
ENCRYPTION_KEY=
# 任意（未設定時は既定値を使用）: セッション有効期限とログインのレート制限
SESSION_TTL_DAYS=30
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_MINUTES=10
# 任意（未設定時は既定値を使用）: 税務AIのモデル名と、アドバイスアップロードのサイズ上限（バイト、既定5MB）
GEMINI_MODEL=gemini-2.0-flash
UPLOAD_MAX_BYTES=5242880
# 任意（未設定時は既定値を使用）: 月次生成cronが何日成功していなければアラートするか（既定35日）
CRON_STALE_ALERT_DAYS=35
